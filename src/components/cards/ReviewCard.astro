---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'reviews'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const formattedDate = data.date.toLocaleDateString('de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const fullStars = Math.floor(data.rating);
const hasHalfStar = data.rating - fullStars >= 0.5;
const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
const stars = '★'.repeat(fullStars) + (hasHalfStar ? '½' : '') + '☆'.repeat(emptyStars);
---

<article class="card">
	<div class="card-meta">
		<span class="badge">Review</span>
		<time datetime={data.date.toISOString()}>{formattedDate}</time>
	</div>
	<h2>{data.title}</h2>
	<div class="film">
		{data.poster && <img src={data.poster} alt={`Poster: ${data.filmTitle}`} loading="lazy" />}
		<div>
			<p class="film-title">{data.filmTitle} ({data.filmYear})</p>
			<p class="rating" aria-label={`Bewertung: ${data.rating} von 5`}>{stars}</p>
		</div>
	</div>
	<div class="body">
		<Content />
	</div>
	<p class="source">
		<a href={data.letterboxdUrl} target="_blank" rel="noopener noreferrer">Auf Letterboxd</a>
	</p>
</article>

<style>
	.card {
		--accent: #b8860b;
		border-left: 4px solid var(--accent);
		padding: 1rem 1.25rem;
		background: color-mix(in srgb, var(--accent) 6%, transparent);
		border-radius: 0 0.5rem 0.5rem 0;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.8rem;
		color: #666;
	}

	.badge {
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-weight: 600;
		color: var(--accent);
	}

	h2 {
		margin: 0.4rem 0;
		font-size: 1.1rem;
	}

	.film {
		display: flex;
		gap: 0.75rem;
		align-items: flex-start;
		margin: 0.5rem 0;
	}

	.film img {
		width: 60px;
		border-radius: 0.3rem;
		flex-shrink: 0;
	}

	.film-title {
		margin: 0;
		font-weight: 600;
	}

	.rating {
		margin: 0.2rem 0 0;
		color: var(--accent);
		letter-spacing: 0.05em;
	}

	.body {
		font-size: 0.95rem;
	}

	.source {
		margin: 0.6rem 0 0;
		font-size: 0.8rem;
		color: #666;
	}
</style>
