---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'shrines'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const formattedDate = data.date.toLocaleDateString('de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const accent = data.accentColor ?? '#6b2d5c';
---

<article class="card" style={`--accent: ${accent}`}>
	<div class="card-meta">
		<span class="badge">Shrine</span>
		<time datetime={data.date.toISOString()}>{formattedDate}</time>
	</div>
	<h2>{data.title}</h2>
	{data.heroImage && <img class="hero" src={data.heroImage} alt={data.subject} loading="lazy" />}
	<p class="subject">{data.subject}</p>
	<div class="body">
		<Content />
	</div>
	{data.gallery && data.gallery.length > 0 && (
		<div class="gallery">
			{data.gallery.map((src) => (
				<img src={src} alt="" loading="lazy" />
			))}
		</div>
	)}
</article>

<style>
	.card {
		border-left: 4px solid var(--accent);
		padding: 1rem 1.25rem;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		border-radius: 0 0.5rem 0.5rem 0;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.8rem;
		color: #666;
	}

	.badge {
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-weight: 600;
		color: var(--accent);
	}

	h2 {
		margin: 0.4rem 0;
		font-size: 1.1rem;
	}

	.hero {
		max-width: 100%;
		border-radius: 0.4rem;
		margin: 0.5rem 0;
	}

	.subject {
		margin: 0 0 0.4rem;
		font-style: italic;
		color: var(--accent);
	}

	.body {
		font-size: 0.95rem;
	}

	.gallery {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.6rem;
		flex-wrap: wrap;
	}

	.gallery img {
		width: 80px;
		height: 80px;
		object-fit: cover;
		border-radius: 0.3rem;
	}
</style>
