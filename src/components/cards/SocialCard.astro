---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'social'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const formattedDate = data.date.toLocaleDateString('de-DE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<article class="card">
	<div class="card-meta">
		<span class="badge">Social</span>
		<time datetime={data.date.toISOString()}>{formattedDate}</time>
	</div>
	<h2>{data.title}</h2>
	{data.image && <img src={data.image} alt="" loading="lazy" />}
	<div class="body">
		<Content />
	</div>
	<p class="source">
		via {data.source} · <a href={data.originalUrl} target="_blank" rel="noopener noreferrer">Original</a>
	</p>
</article>

<style>
	.card {
		--accent: #2b7a8c;
		border-left: 4px solid var(--accent);
		padding: 1rem 1.25rem;
		background: color-mix(in srgb, var(--accent) 6%, transparent);
		border-radius: 0 0.5rem 0.5rem 0;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.8rem;
		color: #666;
	}

	.badge {
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-weight: 600;
		color: var(--accent);
	}

	h2 {
		margin: 0.4rem 0;
		font-size: 1.1rem;
	}

	img {
		max-width: 100%;
		border-radius: 0.4rem;
		margin: 0.5rem 0;
	}

	.body {
		font-size: 0.95rem;
	}

	.source {
		margin: 0.6rem 0 0;
		font-size: 0.8rem;
		color: #666;
	}
</style>
